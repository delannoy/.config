# [The LXPLUS Service](https://lxplusdoc.web.cern.ch/)

Host august
    User                        root
    Hostname                    %h.cern.ch
    PreferredAuthentications    publickey
    IdentityFile                ~/.ssh/keys/id_rsa_august
    IdentitiesOnly              yes

Host pltoffline
    Hostname                    %h.cern.ch

# [The LxTunnel Sevice](https://cern.service-now.com/service-portal?id=kb_article&n=KB0008504)
# > 2FA for external connections will apply only to Kerberos and password logins (*SSH key logins excluded*), but any SSH cross-logins from LXTUNNEL to LXPLUS will be blocked to prevent bypassing 2FA.
# https://resources-old.web.cern.ch/resources-old/Manage/Accounts/MapSSH.aspx
Host lxplus_tunnel
    Hostname                    lxtunnel.cern.ch
    PreferredAuthentications    publickey
    IdentityFile                ~/.ssh/keys/id_rsa_lxtunnel
    IdentitiesOnly              yes

# [List of LXPLUS Aliases](https://lxplusdoc.web.cern.ch/evolution/list/)
Host lxplus lxplus-future lxplus-gpu lxplus-testing
    Hostname                    %h.cern.ch
Host lxplus8 lxplus8-arm lxplus8-future
    Hostname                    %h.cern.ch
Host lxplus9 lxplus9-arm lxplus9-future
    Hostname                    %h.cern.ch

# [CERN OpenStack](https://openstack.cern.ch/project/)
# https://gitlab.cern.ch/adelanno/openstack/-/blob/master/openstack.sh
Host brilvmlxa brilvmlxb brilvmlxc brilvmlxd brilvmlxe brilvmlxf
    Hostname                    %h.cern.ch
Host delannoy0 delannoy000
    Hostname                    %h.cern.ch

Match host="*.cern.ch"
    User                        adelanno

# if `cmsusr.cern.ch` is not ping-able (imples external connection), `*.cern.ch` hostnames will tunnel through `lxtunnel.cern.ch`, then `brilvmlxa.cern.ch` (if `lxtunnel.cern.ch` authenticates via ssh keys, `brilvmlxa.cern.ch` skips two-factor authentication)
Match host="*.cern.ch,!lxtunnel.cern.ch" !exec="ping -c 1 -W 0.25 cmsusr.cern.ch >/dev/null 2>&1"
    ProxyJump                   lxplus_tunnel,brilvmlxa
